# =============================================================================
# CogniTest — environment variables
# =============================================================================
# Copy this file to `.env.local` (development) and configure each value in
# Vercel/Netlify project settings (production).
# Never commit `.env.local`. NEVER expose SUPABASE_SERVICE_ROLE_KEY to the
# browser — it bypasses RLS.
# =============================================================================

# Supabase project — required, public.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Service-role key — required for cron jobs / admin scripts. Server-only.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional: site URL used by Supabase Auth for email confirmation links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
